<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - HotelBook</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .status-badge {
      display: inline-block;
      padding: 0.3rem 0.6rem;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
    }
    .status-pending {
      background-color: #fff3cd;
      color: #856404;
    }
    .status-preparing {
      background-color: #cce5ff;
      color: #004085;
    }
    .status-ready {
      background-color: #d4edda;
      color: #155724;
    }
    .status-delivered {
      background-color: #d1ecf1;
      color: #0c5460;
    }
    .status-cancelled {
      background-color: #f8d7da;
      color: #721c24;
    }
    .order-items {
      margin: 0.5rem 0;
    }
    .order-item {
      display: block;
      color: #666;
      margin-bottom: 0.25rem;
    }
    .special-instructions {
      background-color: #f8f9fa;
      padding: 0.5rem;
      border-radius: 8px;
      border-left: 3px solid #007bff;
      font-style: italic;
      color: #495057;
    }
    .order-actions {
      display: flex;
      gap: 0.5rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }
    .btn-sm {
      padding: 0.4rem 0.8rem;
      font-size: 0.85rem;
      border-radius: 6px;
    }
    .btn-danger {
      background-color: #dc3545;
      color: white;
      border: none;
    }
    .btn-danger:hover {
      background-color: #c82333;
    }
  </style>
</head>
<body class="floating-orbs">
  <div class="navbar">
    <h2>HotelBook</h2>
    <button class="menu-toggle" id="menuToggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="nav-links" id="navLinks">
      <a href="/"><i class="fas fa-home"></i> Home</a>
      <a href="/rooms"><i class="fas fa-bed"></i> Rooms</a>
      <a href="/food/menu"><i class="fas fa-utensils"></i> Food</a>
      <a href="/support"><i class="fas fa-headset"></i> Support</a>
      <% if (user) { %>
        <a href="<%= isAdmin ? '/admin' : '/dashboard' %>"><i class="fas fa-user-circle"></i> <%= user.name %></a>
      <% } %>
      <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </div>
  </div>

  <main class="content-section">
    <header class="page-header fade-in">
      <h1 class="gradient-text"><i class="fas fa-tachometer-alt"></i> My Dashboard</h1>
      <p class="subtitle">Manage bookings, room availability, and room-service orders.</p>
    </header>

    <section class="mb-4 fade-in">
      <h2 class="section-title">Room Service Orders</h2>
      <% if (typeof foodOrders !== 'undefined' && foodOrders.length > 0) { %>
        <div class="orders-grid stagger">
          <% foodOrders.slice(0, 6).forEach(order => { %>
            <article class="order-card">
              <div class="admin-header mb-2">
                <h3>Order #<%= order._id.toString().slice(-6).toUpperCase() %></h3>
                <span class="status-badge status-<%= order.status %>">
                  <%= order.status.charAt(0).toUpperCase() + order.status.slice(1).replace('-', ' ') %>
                </span>
              </div>
              <p class="subtitle">Room <%= order.roomNumber %> | <%= new Date(order.orderDate).toLocaleString() %></p>
              <p><strong>Total: &#8377;<%= order.totalPrice %></strong></p>
              <% if (order.items.length > 0) { %>
                <div class="order-items mb-2">
                  <% order.items.forEach(item => { %>
                    <small class="order-item">• <%= item.quantity %>x <%= item.name %> (&#8377;<%= item.price * item.quantity %>)</small>
                  <% }); %>
                </div>
              <% } %>
              <% if (order.specialInstructions) { %>
                <p class="special-instructions"><em>"<%= order.specialInstructions %>"</em></p>
              <% } %>
              <div class="order-actions">
                <% if (order.status === 'pending') { %>
                  <button onclick="cancelOrder('<%= order._id %>')" class="btn btn-danger btn-sm">
                    <i class="fas fa-times"></i> Cancel Order
                  </button>
                <% } %>
                <a href="/food/menu" class="btn btn-secondary btn-sm">
                  <i class="fas fa-plus"></i> Order More
                </a>
              </div>
            </article>
          <% }); %>
        </div>
      <% } else { %>
        <div class="summary-card text-center">
          <h3>No room service orders yet</h3>
          <p class="subtitle">Order delicious meals delivered to your room.</p>
          <a href="/food/menu" class="btn btn-secondary">Order Food</a>
        </div>
      <% } %>
    </section>

    <section class="mb-4 fade-in">
      <h2 class="section-title">Your Bookings</h2>
      <% if (bookings.length === 0) { %>
        <div class="summary-card text-center">
          <h3>No bookings found</h3>
          <p class="subtitle">Start your journey with a new booking.</p>
          <a href="/rooms" class="btn">Browse Rooms</a>
        </div>
      <% } else { %>
        <div class="bookings-grid stagger">
          <% bookings.forEach(booking => { %>
            <article class="booking-card">
              <div class="admin-header mb-2">
                <h3>Room <%= booking.room.roomNumber %> - <%= booking.room.type %></h3>
                <span class="status-badge"><%= booking.status %></span>
              </div>

              <p class="subtitle"><%= new Date(booking.checkIn).toLocaleDateString() %> to <%= new Date(booking.checkOut).toLocaleDateString() %></p>
              <p><strong>Total Amount: &#8377;<%= booking.totalPrice %></strong></p>

              <% if (booking.specialRequests) { %>
                <p><em><%= booking.specialRequests %></em></p>
              <% } %>

              <div class="form-row mt-4">
                <% if (booking.status === 'confirmed') { %>
                  <form action="/booking/<%= booking._id %>/checkin" method="POST">
                    <button type="submit" class="btn btn-secondary"><i class="fas fa-sign-in-alt"></i> Check In</button>
                  </form>
                <% } %>

                <% if (booking.status === 'checked-in') { %>
                  <form action="/booking/<%= booking._id %>/checkout" method="POST">
                    <button type="submit" class="btn"><i class="fas fa-sign-out-alt"></i> Check Out</button>
                  </form>
                <% } %>

                <% if (booking.status === 'checked-out') { %>
                  <button disabled class="btn">Completed</button>
                <% } %>
              </div>
            </article>
          <% }); %>
        </div>
      <% } %>
    </section>

    <section class="mb-4 fade-in">
      <h2 class="section-title">Quick Actions</h2>
      <div class="quick-grid stagger">
        <a href="/rooms" class="quick-card" style="text-decoration:none;">
          <h3><i class="fas fa-search"></i> Find Rooms</h3>
          <p class="subtitle">Browse and book your next stay.</p>
        </a>
        <a href="/food/menu" class="quick-card" style="text-decoration:none;">
          <h3><i class="fas fa-utensils"></i> Order Food</h3>
          <p class="subtitle">Fresh meals in a few taps.</p>
        </a>
        <a href="/support" class="quick-card" style="text-decoration:none;">
          <h3><i class="fas fa-headset"></i> Get Support</h3>
          <p class="subtitle">We are here for you 24/7.</p>
        </a>
      </div>
    </section>
  </main>

  <script src="/js/ui.js"></script>
  <script>
    function cancelOrder(orderId) {
      if (confirm('Are you sure you want to cancel this order? This action cannot be undone.')) {
        fetch(`/food/cancel-order/${orderId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          }
        })
        .then(response => {
          if (response.ok) {
            alert('Order cancelled successfully!');
            location.reload();
          } else {
            alert('Failed to cancel order. Please try again.');
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('An error occurred while cancelling the order.');
        });
      }
    }
    
    console.log('Dashboard script loaded successfully');
  </script>
</body>
</html>
