<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Support - HotelBook</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="floating-orbs">
  <div class="navbar">
    <h2>HotelBook Support</h2>
    <div class="nav-links">
      <a href="/"><i class="fas fa-home"></i> Home</a>
      <a href="/rooms"><i class="fas fa-bed"></i> Rooms</a>
      <% if (user) { %>
        <a href="<%= isAdmin ? '/admin' : '/dashboard' %>"><i class="fas fa-user-circle"></i> <%= user.name %></a>
        <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
      <% } else { %>
        <a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a>
        <a href="/register"><i class="fas fa-user-plus"></i> Register</a>
      <% } %>
    </div>
  </div>

  <section class="support-section">
    <header class="page-header fade-in">
      <h1 class="gradient-text">Contact & Support</h1>
      <p class="subtitle">We are always ready to help with bookings and stay support.</p>
    </header>

    <div class="support-container stagger mb-4">
      <article class="support-card">
        <h3><i class="fas fa-phone"></i> Phone Support</h3>
        <p>Call us for immediate assistance.</p>
        <p class="contact-info">+91 98765 43210</p>
        <p class="hours">Mon-Fri: 9AM-6PM</p>
      </article>

      <article class="support-card">
        <h3><i class="fas fa-envelope"></i> Email Support</h3>
        <p>Reach us via email anytime.</p>
        <p class="contact-info">support@akhotel.com</p>
        <p class="hours">24/7 response</p>
      </article>

      <article class="support-card">
        <h3><i class="fas fa-map-marker-alt"></i> Location</h3>
        <p>Visit our hotel for in-person support.</p>
        <p class="contact-info">123 Hotel Street<br>City, State 12345</p>
        <p class="hours">Open 24 hours</p>
      </article>
    </div>

    <div class="contact-form fade-in">
      <h3>Send us a Message</h3>
      <form action="/support" method="POST">
        <input type="text" name="name" placeholder="Your name" required>
        <input type="email" name="email" placeholder="Your email" required>
        <input type="text" name="subject" placeholder="Subject" required>
        <textarea name="message" placeholder="Your message" rows="5" required></textarea>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>
  </section>

  <footer class="footer">
    <p>&copy; 2026 HotelBook - Hotel Management</p>
  </footer>

  <script src="/js/ui.js"></script>
</body>
</html>
