<nav class="admin-sidebar">
  <div class="sidebar-header">
    <h3><i class="fas fa-hotel"></i> Hotel Admin</h3>
    <% if (typeof user !== 'undefined' && user) { %>
      <small><%= user.name %></small>
    <% } %>
  </div>

  <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
    <div class="flash-message success">
      <i class="fas fa-check-circle"></i>
      <% success.forEach(msg => { %>
        <div><%= msg %></div>
      <% }); %>
    </div>
  <% } %>

  <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
    <div class="flash-message error">
      <i class="fas fa-exclamation-circle"></i>
      <% error.forEach(msg => { %>
        <div><%= msg %></div>
      <% }); %>
    </div>
  <% } %>

  <ul class="nav-list">
    <li><a href="/admin" class="nav-link <%= typeof page === 'dashboard' ? 'active' : '' %>"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
    <li><a href="/admin/rooms" class="nav-link <%= typeof page === 'rooms' ? 'active' : '' %>"><i class="fas fa-bed"></i> Rooms</a></li>
    <li><a href="/admin/bookings" class="nav-link <%= typeof page === 'bookings' ? 'active' : '' %>"><i class="fas fa-calendar-check"></i> Bookings</a></li>
    <li><a href="/admin/food-menu" class="nav-link <%= typeof page === 'food-menu' ? 'active' : '' %>"><i class="fas fa-utensils"></i> Food Menu</a></li>
    <li><a href="/admin/food-orders" class="nav-link <%= typeof page === 'food-orders' ? 'active' : '' %>"><i class="fas fa-concierge-bell"></i> Food Orders</a></li>
    <li><a href="/admin/staff" class="nav-link <%= typeof page === 'staff' ? 'active' : '' %>"><i class="fas fa-users"></i> Staff</a></li>
    <li><a href="/admin/reports" class="nav-link <%= typeof page === 'reports' ? 'active' : '' %>"><i class="fas fa-chart-bar"></i> Reports</a></li>
    <li><a href="/admin/housekeeping" class="nav-link"><i class="fas fa-broom"></i> Housekeeping</a></li>
    <li><a href="/admin/inventory" class="nav-link"><i class="fas fa-boxes"></i> Inventory</a></li>
  </ul>

  <div class="sidebar-footer">
    <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
  </div>
</nav>
