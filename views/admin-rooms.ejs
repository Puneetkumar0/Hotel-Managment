<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - Admin Panel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
  <nav class="navbar">
    <h2>Hotel Admin Panel</h2>
    <div class="nav-links">
      <a href="/admin">Dashboard</a>
      <a href="/rooms">View Site</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>

  <section class="admin-section" style="max-width: 1200px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <h2><%= pageTitle %></h2>
      <a href="/admin/rooms/add" class="btn btn-primary"><i class="fas fa-plus"></i> Add New Room</a>
    </div>

    <div class="rooms-grid">
      <% if (rooms.length > 0) { %>
        <% rooms.forEach(room => { %>
          <div class="room-card">
            <div class="room-info">
              <h3>Room <%= room.roomNumber %></h3>
              <p><strong>Type:</strong> <%= room.type %></p>
              <p><strong>Price:</strong> ₹<%= room.price %> / per day</p>
              <p><strong>Status:</strong> <span class="status-badge <%= room.status === 'available' ? 'status-clean' : 'status-dirty' %>"><%= room.status === 'available' ? 'Available' : 'Not Available' %></span></p>
              <% if (!room.isAvailable && room.status === 'available') { %>
                <p style="color: var(--warning-color); font-size: 0.9rem;"><i class="fas fa-info-circle"></i> Booked until checkout</p>
              <% } %>
              <div style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                <a href="/admin/rooms/edit/<%= room._id %>" class="btn btn-secondary" style="flex: 1; min-width: 80px;">Edit</a>
                <form action="/admin/rooms/toggle/<%= room._id %>" method="POST" style="flex: 1; min-width: 100px; margin: 0;" onsubmit="return confirm('Set room to Available?');">
                  <button type="submit" name="status" value="available" class="btn btn-success <%= room.status === 'available' ? 'btn-disabled' : '' %>" style="width: 100%;">Available</button>
                </form>
                <form action="/admin/rooms/toggle/<%= room._id %>" method="POST" style="flex: 1; min-width: 100px; margin: 0;" onsubmit="return confirm('Set room to Not Available?');">
                  <button type="submit" name="status" value="not_available" class="btn btn-danger <%= room.status === 'not_available' ? 'btn-disabled' : '' %>" style="width: 100%;">Not Avail</button>
                </form>
                <form action="/admin/rooms/delete/<%= room._id %>" method="POST" style="flex: 1; min-width: 80px; margin: 0;" onsubmit="return confirm('Are you sure you want to delete this room?');">
                  <button type="submit" class="btn" style="width: 100%; background: var(--danger-color); color: white;">Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p>No rooms found. <a href="/admin/rooms/add">Add the first one!</a></p>
      <% } %>
    </div>
  </section>
</body>
</html>