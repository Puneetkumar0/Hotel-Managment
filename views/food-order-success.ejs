<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmed - HotelBook</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body style="background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
    <div class="navbar">
        <h2>HotelBook</h2>
        <div class="nav-links">
            <a href="/"><i class="fas fa-home"></i> Home</a>
            <a href="/rooms"><i class="fas fa-bed"></i> Rooms</a>
            <a href="/dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
            <a href="/support"><i class="fas fa-headset"></i> Support</a>
            <% if (user) { %>
              <a href="<%= isAdmin ? '/admin' : '/dashboard' %>"><i class="fas fa-user-circle"></i> <%= user.name %></a>
            <% } %>
            <a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
        </div>
    </div>

    <main style="padding: 5rem 2rem 2rem; max-width: 800px; margin: 0 auto; text-align: center;">
        <div style="background: linear-gradient(135deg, #00b894, #00cec9); color: white; padding: 4rem 2rem; border-radius: 30px; box-shadow: var(--shadow-lg);">
            <i class="fas fa-check-circle" style="font-size: 6rem; margin-bottom: 2rem;"></i>
            <h1 style="font-size: 3.5rem; margin-bottom: 1rem;">Order Confirmed!</h1>
            <p style="font-size: 1.4rem; opacity: 0.95;">Your room service order has been placed successfully</p>
        </div>

        <div style="background: white; border-radius: 20px; box-shadow: var(--shadow); padding: 3rem; margin: 3rem 0;">
            <h2 style="color: var(--dark-color); margin-bottom: 2rem;">
                <i class="fas fa-receipt" style="color: var(--primary-color); margin-right: 1rem;"></i>
                Order #<%= order._id.toString().slice(-6).toUpperCase() %>
            </h2>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; text-align: left; margin-bottom: 2rem;">
                <div>
                    <h4 style="color: #666; margin-bottom: 1rem;">Delivery To:</h4>
                    <p style="font-size: 1.2rem; font-weight: 600; color: var(--dark-color);">
                        Room <%= roomNumber %>
                    </p>
                </div>
                <div>
                    <h4 style="color: #666; margin-bottom: 1rem;">Order Time:</h4>
                    <p style="font-size: 1.2rem; font-weight: 600; color: var(--dark-color);">
                        <%= new Date(order.orderDate).toLocaleString() %>
                    </p>
                </div>
                <div>
                    <h4 style="color: #666; margin-bottom: 1rem;">Status:</h4>
                    <span style="background: linear-gradient(135deg, #00b894, #00cec9); color: white; padding: 0.75rem 1.5rem; border-radius: 25px; font-weight: 600; font-size: 1.1rem;">
                        <i class="fas fa-clock"></i> Preparing
                    </span>
                </div>
            </div>

            <div style="background: linear-gradient(135deg, #f8f9fa, #e9ecef); border-radius: 15px; padding: 2rem; margin-bottom: 2rem;">
                <h4 style="color: var(--dark-color); margin-bottom: 1.5rem; text-align: center;">
                    <i class="fas fa-list" style="margin-right: 0.5rem;"></i>Your Order Items
                </h4>
                <ul style="list-style: none; padding: 0;">
                    <% order.items.forEach(item => { %>
                        <li style="display: flex; justify-content: space-between; align-items: center; padding: 1rem; background: white; border-radius: 10px; margin-bottom: 1rem; box-shadow: var(--shadow-sm);">
                            <div>
                                <div style="font-weight: 600; color: var(--dark-color); margin-bottom: 0.25rem;">
                                    <%= item.quantity %>x <%= item.name %>
                                </div>
                                <% if (item.notes) { %>
                                    <small style="color: #666;">Notes: <%= item.notes %></small>
                                <% } %>
                            </div>
                            <div style="font-weight: 700; color: var(--success-color); font-size: 1.2rem;">
                                ₹<%= (item.price * item.quantity).toFixed(0) %>
                            </div>
                        </li>
                    <% }); %>
                </ul>
                <div style="border-top: 3px solid var(--primary-color); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; font-size: 1.4rem; font-weight: 700;">
                    <span>Total Amount:</span>
                    <span style="color: var(--success-color);">₹<%= order.totalPrice %></span>
                </div>
            </div>

            <% if (order.specialInstructions) { %>
                <div style="background: linear-gradient(135deg, #fff3cd, #ffeaa7); border-left: 5px solid var(--warning-color); padding: 2rem; border-radius: 15px; margin-bottom: 2rem;">
                    <h4 style="color: var(--warning-color); margin-bottom: 1rem;">
                        <i class="fas fa-sticky-note"></i> Special Instructions
                    </h4>
                    <p style="color: #856404; margin: 0; font-size: 1.1rem;"><%= order.specialInstructions %></p>
                </div>
            <% } %>

            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="/dashboard" style="background: linear-gradient(135deg, #667eea 0%, #764ba2); color: white; padding: 1.2rem 3rem; border-radius: 15px; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.3s ease;">
                    <i class="fas fa-tachometer-alt"></i> Back to Dashboard
                </a>
                <a href="/food/menu" style="background: linear-gradient(135deg, #fdcb6e, #e17055); color: white; padding: 1.2rem 3rem; border-radius: 15px; text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.3s ease;">
                    <i class="fas fa-utensils"></i> Order More
                </a>
            </div>
        </div>

        <div style="background: linear-gradient(135deg, #f8f9fa, #e9ecef); padding: 2rem; border-radius: 15px; text-align: center;">
            <p style="color: #666; margin-bottom: 1rem;">
                <i class="fas fa-info-circle" style="color: var(--primary-color); margin-right: 0.5rem;"></i>
                Expected delivery: 25-35 minutes. Track your order in Dashboard.
            </p>
            <p style="color: #999; font-size: 0.95rem;">Order ID: <%= order._id %></p>
        </div>
    </main>
</body>
</html>
