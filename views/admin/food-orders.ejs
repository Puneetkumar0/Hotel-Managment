<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> - Admin Panel</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <style>
    .table-container {
      background: white;
      padding: 2rem;
      border-radius: 15px;
      box-shadow: var(--shadow);
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }
    th, td {
      padding: 1rem;
      text-align: left;
      border-bottom: 1px solid #eee;
    }
    th {
      background-color: #f8f9fa;
    }
    tr:hover {
      background-color: #f1f1f1;
    }
    .status-badge {
      display: inline-block;
      padding: 0.4rem 0.8rem;
      border-radius: 20px;
      font-size: 0.85rem;
      font-weight: 500;
    }
    .status-pending {
      background-color: #fff3cd;
      color: #856404;
    }
    .status-preparing {
      background-color: #cce5ff;
      color: #004085;
    }
    .status-ready {
      background-color: #d4edda;
      color: #155724;
    }
    .status-delivered {
      background-color: #d1ecf1;
      color: #0c5460;
    }
    .status-cancelled {
      background-color: #f8d7da;
      color: #721c24;
    }
    .actions-cell {
      display: flex;
      gap: 0.5rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .status-select {
      padding: 0.4rem 0.6rem;
      border: 1px solid #ddd;
      border-radius: 4px;
      font-size: 0.85rem;
      cursor: pointer;
    }
    .action-btn {
      padding: 0.4rem 0.6rem;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85rem;
      transition: all 0.2s;
    }
    .action-btn-danger {
      background-color: #dc3545;
      color: white;
    }
    .action-btn-danger:hover {
      background-color: #c82333;
    }
    .order-items {
      max-width: 300px;
      font-size: 0.85rem;
    }
    .order-item {
      margin-bottom: 0.25rem;
      padding: 0.25rem;
      background-color: #f8f9fa;
      border-radius: 4px;
    }
    .special-instructions {
      max-width: 200px;
      font-size: 0.85rem;
      font-style: italic;
      color: #666;
    }
    @media (max-width: 768px) {
      .filters-section {
        flex-direction: column;
        gap: 1rem;
      }
      .table-container {
        font-size: 0.8rem;
      }
      th, td {
        padding: 0.5rem;
      }
      .actions-cell {
        flex-direction: column;
        gap: 0.25rem;
      }
      .order-items {
        max-width: 150px;
      }
      .special-instructions {
        max-width: 150px;
      }
    }
  </style>
</head>
<body>
  <%- include('../partials/admin-nav') %>

  <section class="admin-section" style="max-width: 1400px;">
    <h2><%= pageTitle %></h2>

    <!-- Statistics Cards -->
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
      <div class="summary-card" style="text-align: center; padding: 1.5rem;">
        <h3 style="color: #856404; margin: 0;"><%= orders.filter(o => o.status === 'pending').length %></h3>
        <p style="margin: 0.5rem 0 0 0; color: #666;">Pending Orders</p>
      </div>
      <div class="summary-card" style="text-align: center; padding: 1.5rem;">
        <h3 style="color: #004085; margin: 0;"><%= orders.filter(o => o.status === 'preparing').length %></h3>
        <p style="margin: 0.5rem 0 0 0; color: #666;">Preparing</p>
      </div>
      <div class="summary-card" style="text-align: center; padding: 1.5rem;">
        <h3 style="color: #155724; margin: 0;"><%= orders.filter(o => o.status === 'ready').length %></h3>
        <p style="margin: 0.5rem 0 0 0; color: #666;">Ready for Delivery</p>
      </div>
      <div class="summary-card" style="text-align: center; padding: 1.5rem;">
        <h3 style="color: #0c5460; margin: 0;"><%= orders.filter(o => o.status === 'delivered').length %></h3>
        <p style="margin: 0.5rem 0 0 0; color: #666;">Delivered</p>
      </div>
    </div>

    <!-- Filters and Search -->
    <div class="filters-section" style="background: white; padding: 1.5rem; border-radius: 15px; box-shadow: var(--shadow); margin-bottom: 2rem; display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <label for="statusFilter" style="font-weight: 500;">Filter by Status:</label>
        <select id="statusFilter" onchange="filterOrders()" style="padding: 0.5rem; border: 1px solid #ddd; border-radius: 6px;">
          <option value="">All Orders</option>
          <option value="pending">Pending</option>
          <option value="preparing">Preparing</option>
          <option value="ready">Ready</option>
          <option value="delivered">Delivered</option>
          <option value="cancelled">Cancelled</option>
        </select>
      </div>
      
      <div style="display: flex; align-items: center; gap: 0.5rem;">
        <label for="searchInput" style="font-weight: 500;">Search:</label>
        <input type="text" id="searchInput" onkeyup="filterOrders()" placeholder="Search by customer, room, or order ID..." style="padding: 0.5rem; border: 1px solid #ddd; border-radius: 6px; min-width: 250px;">
      </div>

      <button onclick="clearFilters()" style="padding: 0.5rem 1rem; background: #6c757d; color: white; border: none; border-radius: 6px; cursor: pointer;">Clear Filters</button>
      
      <div style="margin-left: auto; display: flex; gap: 0.5rem;">
        <button onclick="refreshPage()" style="padding: 0.5rem 1rem; background: #28a745; color: white; border: none; border-radius: 6px; cursor: pointer;">
          <i class="fas fa-sync-alt"></i> Refresh
        </button>
        <button onclick="printOrders()" style="padding: 0.5rem 1rem; background: #17a2b8; color: white; border: none; border-radius: 6px; cursor: pointer;">
          <i class="fas fa-print"></i> Print
        </button>
        <select id="bulkStatus" style="padding: 0.5rem; border: 1px solid #ddd; border-radius: 6px;">
          <option value="">Bulk Status Update</option>
          <option value="pending">Set to Pending</option>
          <option value="preparing">Set to Preparing</option>
          <option value="ready">Set to Ready</option>
          <option value="delivered">Set to Delivered</option>
          <option value="cancelled">Set to Cancelled</option>
        </select>
        <button onclick="bulkUpdateStatus()" style="padding: 0.5rem 1rem; background: #007bff; color: white; border: none; border-radius: 6px; cursor: pointer;">Apply to Selected</button>
      </div>
    </div>

    <div class="table-container">
      <% if (orders.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th><input type="checkbox" id="selectAll" onchange="toggleAllCheckboxes()"></th>
              <th>Order ID</th>
              <th>Customer</th>
              <th>Room</th>
              <th>Items</th>
              <th>Special Instructions</th>
              <th>Total</th>
              <th>Order Time</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(order => { %>
              <tr>
                <td><input type="checkbox" class="order-checkbox" value="<%= order._id %>"></td>
                <td>#<%= order._id.toString().slice(-6).toUpperCase() %></td>
                <td><%= order.user ? order.user.name + ' (' + order.user.email + ')' : 'User Deleted' %></td>
                <td><%= order.roomNumber || 'N/A' %></td>
                <td>
                  <div class="order-items">
                    <% order.items.forEach(item => { %>
                      <div class="order-item">
                        <%= item.name %> (x<%= item.quantity %>) - ₹<%= item.price * item.quantity %>
                      </div>
                    <% }) %>
                  </div>
                </td>
                <td class="special-instructions"><%= order.specialInstructions || 'None' %></td>
                <td>₹<%= order.totalPrice %></td>
                <td><%= new Date(order.orderDate).toLocaleString() %></td>
                <td>
                  <span class="status-badge status-<%= order.status %>">
                    <%= order.status.charAt(0).toUpperCase() + order.status.slice(1).replace('-', ' ') %>
                  </span>
                </td>
                <td>
                  <div class="actions-cell">
                    <select class="status-select" onchange="updateOrderStatus('<%= order._id %>', this.value)">
                      <option value="">Change Status</option>
                      <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
                      <option value="preparing" <%= order.status === 'preparing' ? 'selected' : '' %>>Preparing</option>
                      <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Ready</option>
                      <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
                      <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    </select>
                    <a href="/admin/food-orders/delete/<%= order._id %>" title="Delete Order" class="action-btn action-btn-danger" onclick="return confirm('Are you sure you want to delete this order?');"><i class="fas fa-trash"></i> Delete</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p>No food orders found.</p>
      <% } %>
    </div>
  </section>

  <script>
    function updateOrderStatus(orderId, newStatus) {
      if (!newStatus) return;
      
      if (confirm(`Are you sure you want to change the order status to "${newStatus}"?`)) {
        fetch(`/admin/food-orders/update-status/${orderId}`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ status: newStatus })
        })
        .then(response => {
          if (response.ok) {
            location.reload();
          } else {
            alert('Failed to update order status');
          }
        })
        .catch(error => {
          console.error('Error:', error);
          alert('An error occurred while updating the status');
        });
      } else {
        // Reset select if user cancels
        location.reload();
      }
    }

    function filterOrders() {
      const statusFilter = document.getElementById('statusFilter').value.toLowerCase();
      const searchTerm = document.getElementById('searchInput').value.toLowerCase();
      const rows = document.querySelectorAll('tbody tr');

      rows.forEach(row => {
        const cells = row.querySelectorAll('td');
        const orderId = cells[1].textContent.toLowerCase();
        const customer = cells[2].textContent.toLowerCase();
        const room = cells[3].textContent.toLowerCase();
        const specialInstructions = cells[5].textContent.toLowerCase();
        const status = cells[8].textContent.toLowerCase().trim();

        const statusMatch = !statusFilter || status.includes(statusFilter);
        const searchMatch = !searchTerm || 
          customer.includes(searchTerm) || 
          room.includes(searchTerm) || 
          orderId.includes(searchTerm) ||
          specialInstructions.includes(searchTerm);

        row.style.display = statusMatch && searchMatch ? '' : 'none';
      });
    }

    function clearFilters() {
      document.getElementById('statusFilter').value = '';
      document.getElementById('searchInput').value = '';
      filterOrders();
    }

    function toggleAllCheckboxes() {
      const selectAll = document.getElementById('selectAll');
      const checkboxes = document.querySelectorAll('.order-checkbox');
      checkboxes.forEach(cb => cb.checked = selectAll.checked);
    }

    async function bulkUpdateStatus() {
      const selectedOrders = Array.from(document.querySelectorAll('.order-checkbox:checked')).map(cb => cb.value);
      const newStatus = document.getElementById('bulkStatus').value;

      if (selectedOrders.length === 0) {
        alert('Please select at least one order');
        return;
      }

      if (!newStatus) {
        alert('Please choose a status to apply');
        return;
      }

      const statusText = newStatus.charAt(0).toUpperCase() + newStatus.slice(1);
      if (!confirm(`Update ${selectedOrders.length} order(s) to "${statusText}" status?`)) {
        return;
      }

      // Show loading state
      const button = document.querySelector('button[onclick="bulkUpdateStatus()"]');
      const originalText = button.textContent;
      button.textContent = 'Updating...';
      button.disabled = true;

      let successCount = 0;
      let errorCount = 0;

      for (const orderId of selectedOrders) {
        try {
          const response = await fetch(`/admin/food-orders/update-status/${orderId}`, {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ status: newStatus })
          });
          
          if (response.ok) {
            successCount++;
          } else {
            errorCount++;
          }
        } catch (error) {
          console.error('Error updating order:', orderId, error);
          errorCount++;
        }
      }

      // Reset button
      button.textContent = originalText;
      button.disabled = false;

      // Show results
      if (errorCount === 0) {
        alert(`Successfully updated ${successCount} order(s) to "${statusText}" status`);
      } else {
        alert(`Bulk update completed: ${successCount} successful, ${errorCount} failed`);
      }
      
      location.reload();
    }

    function refreshPage() {
      const button = document.querySelector('button[onclick="refreshPage()"]');
      const originalText = button.innerHTML;
      button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Refreshing...';
      button.disabled = true;
      
      setTimeout(() => {
        location.reload();
      }, 500);
    }

    function printOrders() {
      const printWindow = window.open('', '_blank');
      const tableContent = document.querySelector('.table-container').innerHTML;
      
      printWindow.document.write(`
        <!DOCTYPE html>
        <html>
          <head>
            <title>Food Orders Report</title>
            <style>
              body { font-family: Arial, sans-serif; margin: 20px; }
              table { width: 100%; border-collapse: collapse; margin-top: 20px; }
              th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
              th { background-color: #f8f9fa; }
              .status-badge { padding: 2px 6px; border-radius: 10px; font-size: 12px; }
              .status-pending { background-color: #fff3cd; color: #856404; }
              .status-preparing { background-color: #cce5ff; color: #004085; }
              .status-ready { background-color: #d4edda; color: #155724; }
              .status-delivered { background-color: #d1ecf1; color: #0c5460; }
              .status-cancelled { background-color: #f8d7da; color: #721c24; }
              h2 { color: #333; text-align: center; }
              .print-header { text-align: center; margin-bottom: 20px; }
              .no-print { display: none; }
              @media print {
                body { margin: 0; }
              }
            </style>
          </head>
          <body>
            <div class="print-header">
              <h2>Food Orders Report</h2>
              <p>Generated on: ${new Date().toLocaleString()}</p>
            </div>
            ${tableContent.replace(/<input[^>]*>/g, '').replace(/<select[^>]*>[\s\S]*?<\/select>/g, '')}
          </body>
        </html>
      `);
      
      printWindow.document.close();
      printWindow.print();
    }
  </script>
</body>
</html>