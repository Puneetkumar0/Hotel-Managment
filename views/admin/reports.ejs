<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Revenue Reports - Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <h2>📊 Reports</h2>
        <div class="nav-links">
            <a href="/admin">Admin Dashboard</a>
        </div>
    </nav>

    <div class="admin-section">
        <div class="form-container">
            <h2>Generate Report</h2>
            <form action="/admin/reports" method="GET">
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="form-group">
                        <label>Start Date:</label>
                        <input type="date" name="startDate" value="<%= startDate %>">
                    </div>
                    <div class="form-group">
                        <label>End Date:</label>
                        <input type="date" name="endDate" value="<%= endDate %>">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary book-btn">Generate Report</button>
            </form>
        </div>

        <h2>Report Summary</h2>
        <div class="metric-grid">
            <div class="metric-card revenue">
                <h3>$<%= totalRevenue %></h3>
                <p>Total Revenue</p>
            </div>
            <div class="metric-card bookings">
                <h3><%= totalBookings %></h3>
                <p>Total Bookings</p>
            </div>
            <div class="metric-card occupancy">
                <h3><%= occupancyRate.toFixed(2) %>%</h3>
                <p>Occupancy Rate</p>
            </div>
            <div class="metric-card" style="background: linear-gradient(135deg, #00b894, #00a085); color: white;">
                <h3>$<%= avgRevenuePerBooking.toFixed(2) %></h3>
                <p>Avg per Booking</p>
            </div>
            <div class="metric-card" style="background: var(--gradient-primary); color: white;">
                <h3>$<%= revpar.toFixed(2) %></h3>
                <p>RevPAR</p>
            </div>
        </div>
    </div>
</body>
</html>
