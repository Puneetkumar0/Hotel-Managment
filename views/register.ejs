<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - HotelBook</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="floating-orbs">
  <div class="navbar">
    <h2>HotelBook</h2>
    <button class="menu-toggle" id="menuToggle">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <div class="nav-links" id="navLinks">
      <a href="/"><i class="fas fa-home"></i> Home</a>
      <a href="/rooms"><i class="fas fa-bed"></i> Rooms</a>
      <a href="/login"><i class="fas fa-sign-in-alt"></i> Login</a>
    </div>
  </div>

  <section class="hero" style="min-height: 100vh; background: linear-gradient(135deg, rgba(167, 139, 250, 0.9), rgba(243, 156, 18, 0.8)), url('/images/room-209.jpg') center/cover no-repeat;">
    <div class="hero-text glass" style="max-width: 520px; padding: 2.5rem; border-radius: 32px;">
      <div class="text-center mb-4">
        <i class="fas fa-user-plus fa-4x" style="color: var(--accent); margin-bottom: 1rem; animation: bounceIn 0.8s ease;"></i>
        <h1 class="gradient-text" style="font-size: 2.2rem; margin-bottom: 0.5rem;"><i class="fas fa-rocket"></i> Join Our Family</h1>
        <p class="subtitle" style="color: rgba(255,255,255,0.9); font-size: 1.1rem;">Create your account and start booking amazing stays</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="flash-message error mb-4" style="background: rgba(231, 76, 60, 0.9); color: white; border-radius: 12px; padding: 1rem;">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
      <% } %>

      <form action="/register" method="POST" style="margin-bottom: 2rem;">
        <div class="form-group">
          <label for="name" style="color: rgba(255,255,255,0.9); font-weight: 600;">
            <i class="fas fa-user" style="color: var(--primary); margin-right: 0.5rem;"></i>Full Name
          </label>
          <input type="text" id="name" name="name" placeholder="Enter your full name"
                 required style="border-radius: 16px; padding: 1rem 1.2rem; font-size: 1rem; background: rgba(255,255,255,0.95);">
        </div>

        <div class="form-group">
          <label for="email" style="color: rgba(255,255,255,0.9); font-weight: 600;">
            <i class="fas fa-envelope" style="color: var(--secondary); margin-right: 0.5rem;"></i>Email Address
          </label>
          <input type="email" id="email" name="email" placeholder="Enter your email address"
                 required style="border-radius: 16px; padding: 1rem 1.2rem; font-size: 1rem; background: rgba(255,255,255,0.95);">
        </div>

        <div class="form-group">
          <label for="phone" style="color: rgba(255,255,255,0.9); font-weight: 600;">
            <i class="fas fa-phone" style="color: var(--tertiary); margin-right: 0.5rem;"></i>Phone Number
          </label>
          <input type="tel" id="phone" name="phone" placeholder="Enter your phone number"
                 style="border-radius: 16px; padding: 1rem 1.2rem; font-size: 1rem; background: rgba(255,255,255,0.95);">
        </div>

        <div class="form-group">
          <label for="password" style="color: rgba(255,255,255,0.9); font-weight: 600;">
            <i class="fas fa-lock" style="color: var(--accent); margin-right: 0.5rem;"></i>Password
          </label>
          <input type="password" id="password" name="password" placeholder="Create a strong password"
                 required style="border-radius: 16px; padding: 1rem 1.2rem; font-size: 1rem; background: rgba(255,255,255,0.95);">
        </div>

        <button type="submit" class="btn btn-accent" style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-top: 1rem;">
          <i class="fas fa-user-plus"></i> Create Your Account
        </button>
      </form>


      <div class="text-center">
        <p style="color: rgba(255,255,255,0.9); margin-bottom: 1rem;">Already have an account?</p>
        <a href="/login" class="btn btn-warm" style="padding: 0.8rem 2rem; border-radius: 25px;">
          <i class="fas fa-sign-in-alt"></i> Sign In Instead
        </a>
      </div>
    </div>
  </section>

  <script src="/js/ui.js"></script>
</body>
</html>
